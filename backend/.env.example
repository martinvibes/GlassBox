# ── GlassBox configuration ───────────────────────────────────────────────
# Copy to .env and fill in. The paper loop runs with NONE of these set.

# Runtime
GLASSBOX_MODE=paper                 # paper | live
GLASSBOX_HEARTBEAT_SECONDS=900      # loop interval (live). 15 min default.
GLASSBOX_DATA_DIR=./data            # JSONL audit log + paper state live here

# ── CMC Agent Hub (perception) ──────────────────────────────────────────
# MCP endpoint: https://mcp.coinmarketcap.com/mcp  header: X-CMC-MCP-API-KEY
CMC_MCP_API_KEY=
CMC_MCP_ENDPOINT=https://mcp.coinmarketcap.com/mcp
# Optional x402 pay-per-call (keyless) path — leave blank to use API key
CMC_X402_ENABLED=false

# ── Reasoning (LLM) ─────────────────────────────────────────────────────
# If unset, GlassBox uses the deterministic heuristic reasoner (no API needed).
ANTHROPIC_API_KEY=
GLASSBOX_LLM_MODEL=claude-opus-4-8

# ── Trust Wallet Agent Kit (execution) ──────────────────────────────────
# Access ID + HMAC secret from portal.trustwallet.com, saved to ~/.twak/
# twak serve exposes the MCP tools; agent-wallet mode = autonomous.
TWAK_ACCESS_ID=
TWAK_HMAC_SECRET=
TWAK_MCP_ENDPOINT=http://127.0.0.1:8787
TWAK_WALLET_ADDRESS=

# ── BNB AI Agent SDK (identity / anchoring) ─────────────────────────────
# ⚠️ TESTNET ONLY at time of writing. Used for ERC-8004 identity + decision
# hash anchoring, NOT for live trade execution.
BNB_AGENT_PRIVATE_KEY=
BNB_RPC_URL=https://bsc-testnet-dataseed.bnbchain.org
BNB_ANCHORING_ENABLED=false
