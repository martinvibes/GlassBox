# ── GlassBox configuration ───────────────────────────────────────────────
# Copy to .env and fill in. The paper loop runs with NONE of these set.

# Runtime
# NOTE: perception is ALWAYS real market data (CoinGecko + alternative.me, keyless;
# CMC Agent Hub when a key is set). GLASSBOX_MODE only controls EXECUTION:
#   paper = simulated fills against real live prices (no wallet needed)
#   live  = real on-chain swaps via TWAK (needs funded wallet + TWAK keys below)
GLASSBOX_MODE=paper                 # paper | live
GLASSBOX_HEARTBEAT_SECONDS=900      # loop interval. 15 min default.
GLASSBOX_DATA_DIR=./data            # JSONL audit log + portfolio state live here

# ── CMC Agent Hub (perception) ──────────────────────────────────────────
# MCP endpoint: https://mcp.coinmarketcap.com/mcp  header: X-CMC-MCP-API-KEY
CMC_MCP_API_KEY=
CMC_MCP_ENDPOINT=https://mcp.coinmarketcap.com/mcp
# Optional x402 pay-per-call (keyless) path — leave blank to use API key
CMC_X402_ENABLED=false

# ── Reasoning (LLM) ─────────────────────────────────────────────────────
# If unset, GlassBox uses the deterministic heuristic reasoner (no API needed).
ANTHROPIC_API_KEY=
GLASSBOX_LLM_MODEL=claude-opus-4-8

# ── Trust Wallet Agent Kit (execution) ──────────────────────────────────
# 1) npm i -g @trustwallet/cli
# 2) Create an app + API key at https://portal.trustwallet.com (HMAC secret shown ONCE)
# 3) twak wallet create --password "<pw>"   then fund the agent wallet with BNB+USDT
# Auth is HMAC-SHA256; the CLI signs locally with the keystore in ~/.twak/.
TWAK_ACCESS_ID=
TWAK_HMAC_SECRET=
TWAK_WALLET_ADDRESS=
TWAK_WALLET_PASSWORD=
TWAK_MCP_ENDPOINT=https://mcp.trustwallet.com/tws

# ── On-chain proof: ERC-8004 identity + decision anchoring ──────────────
# Done via the `twak erc8004` CLI (registry deployed on bsc AND bsctestnet).
# Uses the same TWAK wallet above — no separate private key needed.
# Anchoring costs gas; keep OFF until the live window / demo.
BNB_ANCHORING_ENABLED=false
GLASSBOX_ANCHOR_CHAIN=bsc            # bsc (mainnet) | bsctestnet (gas-free dev)
# (Optional) only if you later integrate the bnbagent Python SDK directly:
BNB_AGENT_PRIVATE_KEY=
BNB_RPC_URL=
